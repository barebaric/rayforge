msgstr ""
"La machine a signalé un code d'alarme non reconnu. Consultez la "
"documentation de votre machine et de votre firmware."

#: rayforge/machine/driver/grbl/grbl_util.py
msgid "Unknown Error"
msgstr "Erreur inconnue"

#: rayforge/machine/driver/grbl/grbl_util.py
