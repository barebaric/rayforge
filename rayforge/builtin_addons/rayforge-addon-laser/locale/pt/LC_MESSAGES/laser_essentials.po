msgid "Engrave"
msgstr "Gravar"

#: laser_essentials/material_test_helpers.py
msgid "Power vs Speed"
msgstr "Potência vs Velocidade"

#: laser_essentials/material_test_helpers.py
msgid "Power vs Passes"
msgstr "Potência vs Passagens"

#: laser_essentials/material_test_helpers.py
msgid "Speed vs Passes"
msgstr "Velocidade vs Passagens"

#: laser_essentials/material_test_helpers.py
msgid "Speed vs Offset"
msgstr "Velocidade vs Deslocamento"

#: laser_essentials/widgets/wavefront_widget.py
msgid "Step Over"
msgstr "Passo lateral"

#: laser_essentials/widgets/wavefront_widget.py
msgid "Lateral step-over between wavefront passes (mm)"
msgstr "Passo lateral entre passagens de frente de onda (mm)"

#: laser_essentials/widgets/wavefront_widget.py
msgid "Offset"
msgstr "Deslocamento"

#: laser_essentials/widgets/wavefront_widget.py
msgid "Extra offset from walls (mm)"
msgstr "Deslocamento extra de paredes (mm)"

#: laser_essentials/widgets/raster_widget.py
msgid "Configure how the laser engraves your image."
msgstr "Configurar como o laser grava a sua imagem."

#: laser_essentials/widgets/raster_widget.py
msgid "Mode"
msgstr "Modo"

#: laser_essentials/widgets/raster_widget.py
msgid "Threshold"
msgstr "Limiar"

#: laser_essentials/widgets/raster_widget.py
msgid "Brightness cutoff for black/white (0-255)"
msgstr "Limite de brilho para preto/branco (0-255)"

#: laser_essentials/widgets/raster_widget.py
msgid "Engraving Method"
msgstr "Método de Gravação"

#: laser_essentials/widgets/raster_widget.py
msgid "Algorithm for converting grayscale to binary"
msgstr "Algoritmo para converter tons de cinza para binário"

#: laser_essentials/widgets/raster_widget.py
msgid "Auto Levels"
msgstr "Níveis Automáticos"

#: laser_essentials/widgets/raster_widget.py
msgid "Automatically adjust black/white points"
msgstr "Ajustar automaticamente pontos preto/branco"

#: laser_essentials/widgets/raster_widget.py
msgid "Brightness Range"
msgstr "Intervalo de Brilho"

#: laser_essentials/widgets/raster_widget.py
msgid "Auto-adjusted based on image content"
msgstr "Ajustado automaticamente com base no conteúdo da imagem"

#: laser_essentials/widgets/raster_widget.py
msgid "Drag markers to set black/white points"
msgstr "Arraste os marcadores para definir pontos de preto/branco"

#: laser_essentials/widgets/raster_widget.py
msgid "Min Power"
msgstr "Potência Mínima"

#: laser_essentials/widgets/raster_widget.py
#, python-format
msgid "Power for lightest areas, as a % of the step's main power"
msgstr ""
"Potência para as áreas mais claras, como uma % da potência principal da etapa"

#: laser_essentials/widgets/raster_widget.py
msgid "Max Power"
msgstr "Potência Máxima"

#: laser_essentials/widgets/raster_widget.py
#, python-format
msgid "Power for darkest areas, as a % of the step's main power"
msgstr ""
"Potência para as áreas mais escuras, como uma % da potência principal da "
"etapa"

#: laser_essentials/widgets/raster_widget.py
msgid "Power Levels"
msgstr "Níveis de Potência"

#: laser_essentials/widgets/raster_widget.py
msgid "Number of discrete power steps (lower = fewer moves)"
msgstr "Número de etapas discretas de potência (menor = menos movimentos)"

#: laser_essentials/widgets/raster_widget.py
msgid "Number of Depth Levels"
msgstr "Número de Níveis de Profundidade"

#: laser_essentials/widgets/raster_widget.py
msgid "Z Step-Down per Level (mm)"
msgstr "Recuo em Z por Nível (mm)"

#: laser_essentials/widgets/raster_widget.py
msgid "Rotate Angle Per Pass"
msgstr "Ângulo de Rotação Por Passagem"

#: laser_essentials/widgets/raster_widget.py
msgid "Degrees to rotate each successive pass"
msgstr "Graus para rodar cada passagem sucessiva"

#: laser_essentials/widgets/raster_widget.py
msgid "Engraving Pattern"
msgstr "Padrão de Gravação"

#: laser_essentials/widgets/raster_widget.py
msgid "Settings that control the scan line pattern and orientation."
msgstr ""
"Definições que controlam o padrão e orientação das linhas de varredura."

#: laser_essentials/widgets/raster_widget.py
msgid "Angle"
msgstr "Ângulo"

#: laser_essentials/widgets/raster_widget.py
msgid "Angle of scan lines in degrees"
msgstr "Ângulo das linhas de varredura em graus"

#: laser_essentials/widgets/raster_widget.py
msgid "Cross-Hatch"
msgstr "Hachura Cruzada"

#: laser_essentials/widgets/raster_widget.py
msgid "Add a second pass at 90 degrees"
msgstr "Adicionar uma segunda passagem a90 graus"

#: laser_essentials/widgets/raster_widget.py
msgid "Segmented"
msgstr "Segmentado"

#: laser_essentials/widgets/raster_widget.py
msgid "Full Sweep"
msgstr "Varredura completa"

#: laser_essentials/widgets/raster_widget.py
msgid "Scan Mode"
msgstr "Modo de varredura"

#: laser_essentials/widgets/raster_widget.py
msgid ""
"Segmented: moves between content regions. Full Sweep: scans full width with "
"laser toggling."
msgstr ""
"Segmentado: move-se entre regiões de conteúdo. Varredura completa: varre "
"toda a largura com ativação do laser."

#: laser_essentials/widgets/raster_widget.py
msgid "Line Spacing"
msgstr "Espaçamento de Linha"

#: laser_essentials/widgets/raster_widget.py
msgid "Distance between scan lines"
msgstr "Distância entre linhas de varredura"

#: laser_essentials/widgets/raster_widget.py
msgid "Sample Interval"
msgstr "Intervalo de Amostragem"

#: laser_essentials/widgets/raster_widget.py
msgid ""
"Distance between power samples along scan line. Lower values improve "
"accuracy, but increase output size."
msgstr ""
"Distância entre amostras de potência ao longo da linha de varredura. Valores "
"mais baixos melhoram a precisão, mas aumentam o tamanho da saída."

#: laser_essentials/widgets/raster_widget.py
msgid "Bidirectional Scan Offset"
msgstr "Deslocamento de varredura bidirecional"

#: laser_essentials/widgets/raster_widget.py
msgid ""
"Corrects X misalignment between left-to-right and right-to-left raster "
"passes (in mm)"
msgstr ""
"Corrige o desalinhamento X entre as passadas raster da esquerda para a "
"direita e da direita para a esquerda (em mm)"

#: laser_essentials/widgets/raster_widget.py
msgid "Invert"
msgstr "Inverter"

#: laser_essentials/widgets/raster_widget.py
msgid "Engrave white areas instead of black areas"
msgstr "Gravar áreas brancas em vez de áreas pretas"

#: laser_essentials/widgets/raster_widget.py
msgid "Change Power Range"
msgstr "Alterar Faixa de Potência"

#: laser_essentials/widgets/raster_widget.py
msgid "Min Power (Black)"
msgstr "Potência Mínima (Preto)"

#: laser_essentials/widgets/raster_widget.py
msgid "Max Power (White)"
msgstr "Potência Máxima (Branco)"

#: laser_essentials/widgets/raster_widget.py
msgid "Min Power (White)"
msgstr "Potência Mín. (Branco)"

#: laser_essentials/widgets/raster_widget.py
msgid "Max Power (Black)"
msgstr "Potência Máx. (Preto)"

#: laser_essentials/widgets/shrinkwrap_widget.py
msgid "Gravity"
msgstr "Gravidade"

#: laser_essentials/widgets/shrinkwrap_widget.py
msgid "Pulls the hull inward. 0.0 is a standard convex hull"
msgstr "Puxa o invólucro para dentro. 0.0 é um invólucro convexo padrão."

#: laser_essentials/widgets/shrinkwrap_widget.py
#: laser_essentials/widgets/frame_widget.py
#: laser_essentials/widgets/contour_widget.py
msgid "Cut Side"
msgstr "Lado de Corte"

#: laser_essentials/widgets/shrinkwrap_widget.py
#: laser_essentials/widgets/frame_widget.py
#: laser_essentials/widgets/contour_widget.py
msgid "Path Offset"
msgstr "Deslocamento do caminho"

#: laser_essentials/widgets/shrinkwrap_widget.py
#: laser_essentials/widgets/contour_widget.py
msgid ""
"Absolute distance from original path in machine units, direction is "
"controlled by Cut Side"
msgstr ""
"Distância absoluta do caminho original em unidades de máquina, a direção é "
"controlada pelo lado de corte"

#: laser_essentials/widgets/frame_widget.py
msgid "Absolute distance from content boundary in machine units"
msgstr "Distância absoluta do limite do conteúdo em unidades de máquina"

#: laser_essentials/widgets/contour_widget.py
msgid "Remove Inner Paths"
msgstr "Remover Caminhos Internos"

#: laser_essentials/widgets/contour_widget.py
msgid "If enabled, only trace the outer outline of shapes"
msgstr "Se ativado, traça apenas o contorno externo das formas."

#: laser_essentials/widgets/contour_widget.py
msgid "Cut Order"
msgstr "Ordem de Corte"

#: laser_essentials/widgets/contour_widget.py
msgid "Processing order for nested paths"
msgstr "Ordem de processamento para caminhos aninhados"

#: laser_essentials/widgets/contour_widget.py
msgid "Overcut"
msgstr "Sobrecorte"

#: laser_essentials/widgets/contour_widget.py
msgid ""
"Extend closed contours past their start point so the cut overlaps itself"
msgstr ""
"Estender contornos fechados além do ponto de início para que o corte se "
"sobreponha"

#: laser_essentials/widgets/contour_widget.py
msgid "Rescan Content"
msgstr "Reexaminar Conteúdo"

