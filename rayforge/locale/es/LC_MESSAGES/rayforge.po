msgstr "El servidor cerró la conexión WebSocket."

#: rayforge/machine/driver/octoprint/octoprint_driver.py
msgid "Print Failed"
msgstr "Impresión fallida"

#: rayforge/machine/driver/octoprint/octoprint_driver.py
msgid ""
"OctoPrint reported that the print job failed. Check OctoPrint for details."
msgstr ""
"OctoPrint informó que el trabajo de impresión falló. Verifique OctoPrint "
"para más detalles."

