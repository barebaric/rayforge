msgid "Print Failed"
msgstr "Druck fehlgeschlagen"

#: rayforge/machine/driver/octoprint/octoprint_driver.py
msgid ""
"OctoPrint reported that the print job failed. Check OctoPrint for details."
msgstr ""
"OctoPrint hat gemeldet, dass der Druckauftrag fehlgeschlagen ist. Überprüfe "
"OctoPrint für Details."

