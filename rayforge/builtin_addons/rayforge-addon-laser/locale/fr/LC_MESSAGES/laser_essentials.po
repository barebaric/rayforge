msgid "Min Power"
msgstr "Puissance minimale"

#: laser_essentials/widgets/raster_widget.py
#, python-format
msgid "Power for lightest areas, as a % of the step's main power"
msgstr ""
"Puissance pour les zones les plus claires, en % de la puissance principale "
"de l’étape"

