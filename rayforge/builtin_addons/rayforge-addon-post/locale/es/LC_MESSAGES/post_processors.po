#: post_processors/widgets/overscan_widget.py
msgid "Enable Overscan"
msgstr "Habilitar sobrecorrido"

#: post_processors/widgets/overscan_widget.py
msgid "Automatic Distance"
msgstr "Distancia automática"

#: post_processors/widgets/overscan_widget.py
msgid "Calculate distance based on speed and acceleration with safety factor"
msgstr ""
"Calcular distancia basada en velocidad y aceleración con factor de seguridad"

#: post_processors/widgets/overscan_widget.py
msgid "Overscan Distance"
msgstr "Distancia de sobrecorrido"

#: post_processors/widgets/overscan_widget.py
msgid "Manual distance setting"
msgstr "Configuración de distancia manual"

#: post_processors/widgets/overscan_widget.py
msgid "Toggle Overscan"
msgstr "Alternar sobrecorrido"

#: post_processors/widgets/overscan_widget.py
msgid "Toggle Auto Overscan"
msgstr "Alternar sobrecorrido automático"

#: post_processors/widgets/overscan_widget.py
msgid "Auto Calculate Overscan Distance"
msgstr "Calcular automáticamente distancia de sobrecorrido"

#: post_processors/widgets/overscan_widget.py
msgid "Disable Auto Overscan"
msgstr "Desactivar sobrecorrido automático"

#: post_processors/widgets/overscan_widget.py
msgid "Change Overscan Distance"
msgstr "Cambiar distancia de sobrecorrido"

#: post_processors/widgets/optimize_widget.py
msgid "Enable Optimization"
msgstr "Habilitar optimización"

#: post_processors/widgets/optimize_widget.py
msgid "Minimizes travel distance by reordering segments"
msgstr "Minimiza la distancia de viaje reordenando segmentos"

#: post_processors/widgets/optimize_widget.py
msgid "Allow Flipping"
msgstr "Permitir inversión"

#: post_processors/widgets/optimize_widget.py
msgid "Allow reversing path direction for shorter travel"
msgstr ""
"Permitir invertir la dirección de la trayectoria para viajes más cortos"

#: post_processors/widgets/optimize_widget.py
msgid "Preserve First Workpiece"
msgstr "Preservar primera pieza"

#: post_processors/widgets/optimize_widget.py
msgid "Keep the first workpiece at its original position"
msgstr "Mantener la primera pieza en su posición original"

#: post_processors/widgets/optimize_widget.py
msgid "Toggle Path Optimization"
msgstr "Alternar optimización de trayectoria"

#: post_processors/widgets/optimize_widget.py
msgid "Toggle Flipping"
msgstr "Alternar inversión"

#: post_processors/widgets/optimize_widget.py
msgid "Toggle Preserve First Workpiece"
msgstr "Alternar preservación de primera pieza"

#: post_processors/widgets/crop_widget.py
msgid "Enable Crop-to-Stock"
msgstr "Habilitar recorte al material"

#: post_processors/widgets/crop_widget.py
msgid "Removes toolpaths extending beyond stock boundary"
msgstr ""
"Elimina trayectorias de herramienta que se extienden más allá del límite del "
"material"

#: post_processors/widgets/crop_widget.py
msgid "Offset"
msgstr "Desplazamiento"

#: post_processors/widgets/crop_widget.py
msgid "Grow/shrink stock boundary before cropping"
msgstr "Ampliar/reducir el límite del material antes de recortar"

#: post_processors/widgets/crop_widget.py
msgid "Toggle Crop-to-Stock"
msgstr "Alternar recorte al material"

#: post_processors/widgets/crop_widget.py
msgid "Change Crop Offset"
msgstr "Cambiar desplazamiento de recorte"

#: post_processors/widgets/smooth_widget.py
msgid "Enable Smoothing"
msgstr "Habilitar suavizado"

#: post_processors/widgets/smooth_widget.py
msgid "Smooths jagged edges using a Gaussian filter"
msgstr "Suaviza bordes irregulares usando un filtro gaussiano"

#: post_processors/widgets/smooth_widget.py
msgid "Smoothness"
msgstr "Suavidad"

#: post_processors/widgets/smooth_widget.py
msgid "Higher values produce smoother curves"
msgstr "Valores más altos producen curvas más suaves"

#: post_processors/widgets/smooth_widget.py
msgid "Corner Angle Threshold"
msgstr "Umbral de ángulo de esquina"

#: post_processors/widgets/smooth_widget.py
msgid "Angles sharper than this are kept as corners (degrees)"
msgstr "Ángulos más agudos que esto se mantienen como esquinas (grados)"

#: post_processors/widgets/smooth_widget.py
msgid "Toggle Smoothing"
msgstr "Alternar suavizado"

#: post_processors/widgets/smooth_widget.py
msgid "Change smoothness"
msgstr "Cambiar suavidad"

#: post_processors/widgets/smooth_widget.py
msgid "Change corner angle"
msgstr "Cambiar ángulo de esquina"

#: post_processors/widgets/multipass_widget.py
msgid "Number of Passes"
msgstr "Número de pasadas"

#: post_processors/widgets/multipass_widget.py
msgid "How often to repeat the entire step"
msgstr "Con qué frecuencia repetir todo el paso"

#: post_processors/widgets/multipass_widget.py
msgid "Z Step-Down per Pass"
msgstr "Descenso en Z por pasada"

#: post_processors/widgets/multipass_widget.py
msgid "Distance to lower Z-axis for each subsequent pass in machine units"
msgstr ""
"Distancia para bajar el eje Z para cada pasada subsiguiente en unidades de "
"máquina"

#: post_processors/widgets/multipass_widget.py
msgid "Change number of passes"
msgstr "Cambiar número de pasadas"

#: post_processors/widgets/multipass_widget.py
msgid "Change Z Step-Down"
msgstr "Cambiar descenso en Z"

#: post_processors/transformers/optimize_transformer.py
msgid "Optimize Path"
msgstr "Optimizar trayectoria"

#: post_processors/transformers/optimize_transformer.py
msgid "Minimizes travel distance by reordering segments."
msgstr "Minimiza la distancia de viaje reordenando segmentos."

#: post_processors/transformers/optimize_transformer.py
msgid "Analyzing workpieces..."
msgstr "Analizando piezas..."

#: post_processors/transformers/optimize_transformer.py
msgid "Optimizing workpiece order..."
msgstr "Optimizando orden de piezas..."

#: post_processors/transformers/optimize_transformer.py
msgid "Applying 2-opt refinement..."
msgstr "Aplicando refinamiento 2-opt..."

#: post_processors/transformers/optimize_transformer.py
msgid "Reassembling optimized workpieces..."
msgstr "Reensamblando piezas optimizadas..."

#: post_processors/transformers/optimize_transformer.py
msgid "Workpiece optimization complete"
msgstr "Optimización de pieza completada"

#: post_processors/transformers/optimize_transformer.py
msgid "Preprocessing for optimization..."
msgstr "Preprocesando para optimización..."

#: post_processors/transformers/optimize_transformer.py
msgid "Analyzing and bucketing path segments..."
msgstr "Analizando y agrupando segmentos de trayectoria..."

#: post_processors/transformers/optimize_transformer.py
#, python-brace-format
msgid "Optimizing segment {i}/{total}..."
msgstr "Optimizando segmento {i}/{total}..."

#: post_processors/transformers/optimize_transformer.py
msgid "Finding nearest paths..."
msgstr "Buscando trayectorias más cercanas..."

#: post_processors/transformers/optimize_transformer.py
msgid "Reassembling optimized paths..."
msgstr "Reensamblando trayectorias optimizadas..."

#: post_processors/transformers/optimize_transformer.py
msgid "Optimization complete"
msgstr "Optimización completada"

#: post_processors/transformers/smooth_transformer.py
msgid "Smooth Path"
msgstr "Suavizar trayectoria"

#: post_processors/transformers/smooth_transformer.py
msgid "Smooths the path by applying a Gaussian filter."
msgstr "Suaviza la trayectoria aplicando un filtro gaussiano."

#: post_processors/transformers/overscan_transformer.py
msgid "Overscan"
msgstr "Sobrecorrido"

#: post_processors/transformers/overscan_transformer.py
msgid "Extends raster lines to ensure constant engraving speed."
msgstr "Extiende líneas de trama para asegurar velocidad de grabado constante."

#: post_processors/transformers/crop_transformer.py
msgid "Crop to Stock"
msgstr "Recortar al material"

#: post_processors/transformers/crop_transformer.py
msgid "Crops cutting lines to stock boundary."
msgstr "Recorta líneas de corte al límite del material."

#: post_processors/transformers/multipass_transformer.py
msgid "Multi-Pass"
msgstr "Multipasada"

#: post_processors/transformers/multipass_transformer.py
msgid "Repeats the path multiple times, optionally stepping down in Z."
msgstr "Repite la trayectoria múltiples veces, opcionalmente bajando en Z."

#: post_processors/transformers/tabs_transformer.py
msgid "Tabs"
msgstr "Pestañas de sujeción"

#: post_processors/transformers/tabs_transformer.py
msgid "Creates holding tabs by adding gaps or reducing power on cut paths"
msgstr ""
"Crea pestañas de sujeción añadiendo huecos o reduciendo potencia en "
"trayectorias de corte"
