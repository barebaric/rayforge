msgid "Max Power"
msgstr "Puissance max."

#: laser_essentials/widgets/raster_widget.py
#, python-format
msgid "Power for darkest areas, as a % of the step's main power"
msgstr ""
"Puissance pour les zones les plus sombres, en % de la puissance principale "
"de l’étape"

