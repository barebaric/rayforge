#: rayforge/machine/models/dialect/grbl_raster.py
msgid "GRBL Raster"
msgstr "GRBL 栅格"

#: rayforge/machine/models/dialect/grbl_raster.py
msgid ""
"Optimized for GRBL raster engraving. Keeps M4 dynamic power mode "
"continuously active and uses modal feedrate to minimize command overhead "
"during scan lines"
