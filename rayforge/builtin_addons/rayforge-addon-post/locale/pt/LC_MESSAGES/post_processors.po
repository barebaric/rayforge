#: post_processors/widgets/lead_in_out_widget.py
#: post_processors/widgets/overscan_widget.py
msgid "Automatic Distance"
msgstr "Distância Automática"

#: post_processors/widgets/lead_in_out_widget.py
#: post_processors/widgets/overscan_widget.py
msgid "Calculate distance based on speed and acceleration with safety factor"
msgstr ""
"Calcular distância baseada em velocidade e aceleração com fator de segurança"

#: post_processors/widgets/lead_in_out_widget.py
msgid "Lead-In Distance"
msgstr "Distância de entrada"

#: post_processors/widgets/lead_in_out_widget.py
msgid "Distance of zero-power move before cut starts"
msgstr "Distância do movimento sem potência antes de iniciar o corte"

#: post_processors/widgets/lead_in_out_widget.py
msgid "Lead-Out Distance"
msgstr "Distância de saída"

#: post_processors/widgets/lead_in_out_widget.py
msgid "Distance of zero-power move after cut ends"
msgstr "Distância do movimento sem potência após o fim do corte"

#: post_processors/widgets/lead_in_out_widget.py
msgid "Toggle Auto Lead-In/Out"
msgstr "Alternar entrada/saída automática"

#: post_processors/widgets/lead_in_out_widget.py
msgid "Auto Calculate Lead-In/Out Distance"
msgstr "Calcular automaticamente a distância de entrada/saída"

#: post_processors/widgets/lead_in_out_widget.py
msgid "Disable Auto Lead-In/Out"
msgstr "Desativar entrada/saída automática"

#: post_processors/widgets/lead_in_out_widget.py
msgid "Change Lead-In Distance"
msgstr "Alterar distância de entrada"

#: post_processors/widgets/lead_in_out_widget.py
msgid "Change Lead-Out Distance"
msgstr "Alterar distância de saída"

#: post_processors/widgets/overscan_widget.py
msgid "Overscan Distance"
msgstr "Distância do Sobrescan"

#: post_processors/widgets/overscan_widget.py
msgid "Manual distance setting"
msgstr "Configuração manual de distância"

#: post_processors/widgets/overscan_widget.py
msgid "Toggle Auto Overscan"
msgstr "Alternar Sobrescan Automático"

#: post_processors/widgets/overscan_widget.py
msgid "Auto Calculate Overscan Distance"
msgstr "Calcular Automaticamente Distância do Sobrescan"

#: post_processors/widgets/overscan_widget.py
msgid "Disable Auto Overscan"
msgstr "Desativar Sobrescan Automático"

#: post_processors/widgets/overscan_widget.py
msgid "Change Overscan Distance"
msgstr "Alterar Distância do Sobrescan"

#: post_processors/widgets/optimize_widget.py
msgid "Allow Flipping"
msgstr "Permitir Inversão"

#: post_processors/widgets/optimize_widget.py
msgid "Allow reversing path direction for shorter travel"
msgstr "Permitir inverter a direção do caminho para deslocamento mais curto"

#: post_processors/widgets/optimize_widget.py
msgid "Preserve First Workpiece"
msgstr "Preservar Primeira Peça de Trabalho"

#: post_processors/widgets/optimize_widget.py
msgid "Keep the first workpiece at its original position"
msgstr "Manter a primeira peça de trabalho em sua posição original"

#: post_processors/widgets/optimize_widget.py
msgid "Toggle Flipping"
msgstr "Alternar Inversão"

#: post_processors/widgets/optimize_widget.py
msgid "Toggle Preserve First Workpiece"
msgstr "Alternar Preservação da Primeira Peça de Trabalho"

#: post_processors/widgets/crop_widget.py
msgid "Offset"
msgstr "Deslocamento"

#: post_processors/widgets/crop_widget.py
msgid "Grow/shrink stock boundary before cropping"
msgstr "Expandir/retrair limite do material antes do recorte"

#: post_processors/widgets/crop_widget.py
msgid "Change Crop Offset"
msgstr "Alterar Deslocamento do Recorte"

#: post_processors/widgets/smooth_widget.py
msgid "Smoothness"
msgstr "Suavidade"

#: post_processors/widgets/smooth_widget.py
msgid "Higher values produce smoother curves"
msgstr "Valores mais altos produzem curvas mais suaves"

#: post_processors/widgets/smooth_widget.py
msgid "Corner Angle Threshold"
msgstr "Limiar de Ângulo de Canto"

#: post_processors/widgets/smooth_widget.py
msgid "Angles sharper than this are kept as corners (degrees)"
msgstr "Ângulos mais agudos que este são mantidos como cantos (graus)"

#: post_processors/widgets/smooth_widget.py
msgid "Change smoothness"
msgstr "Alterar suavidade"

#: post_processors/widgets/smooth_widget.py
msgid "Change corner angle"
msgstr "Alterar ângulo do canto"

#: post_processors/widgets/merge_lines_widget.py
msgid "Tolerance"
msgstr "Tolerância"

#: post_processors/widgets/merge_lines_widget.py
msgid "Maximum distance for lines to be considered overlapping"
msgstr "Distância máxima para que as linhas sejam consideradas sobrepostas"

#: post_processors/widgets/merge_lines_widget.py
msgid "Change merge tolerance"
msgstr "Alterar tolerância de fusão"

#: post_processors/widgets/multipass_widget.py
msgid "Number of Passes"
msgstr "Número de Passagens"

#: post_processors/widgets/multipass_widget.py
msgid "How often to repeat the entire step"
msgstr "Quantas vezes repetir todo o passo"

#: post_processors/widgets/multipass_widget.py
msgid "Z Step-Down per Pass"
msgstr "Descida em Z por Passagem"

#: post_processors/widgets/multipass_widget.py
msgid "Distance to lower Z-axis for each subsequent pass in machine units"
msgstr ""
"Distância para baixar o eixo Z para cada passagem subsequente em unidades da "
"máquina"

#: post_processors/widgets/multipass_widget.py
msgid "Change number of passes"
msgstr "Alterar número de passagens"

#: post_processors/widgets/multipass_widget.py
msgid "Change Z Step-Down"
msgstr "Alterar Descida em Z"

#: post_processors/transformers/lead_in_out_transformer.py
msgid "Lead-In/Out"
msgstr "Entrada/Saída"

#: post_processors/transformers/lead_in_out_transformer.py
msgid "Adds zero-power lead-in and lead-out moves to vector contours."
msgstr ""
"Adiciona movimentos de entrada e saída sem potência aos contornos vetoriais."

#: post_processors/transformers/optimize_transformer.py
msgid "Optimize Path"
msgstr "Otimizar Caminho"

#: post_processors/transformers/optimize_transformer.py
msgid "Minimizes travel distance by reordering segments."
msgstr "Minimiza a distância de deslocamento reordenando segmentos."

#: post_processors/transformers/optimize_transformer.py
msgid "Analyzing workpieces..."
msgstr "Analisando peças de trabalho..."

#: post_processors/transformers/optimize_transformer.py
msgid "Optimizing workpiece order..."
msgstr "Otimizando ordem das peças de trabalho..."

#: post_processors/transformers/optimize_transformer.py
msgid "Applying 2-opt refinement..."
msgstr "Aplicando refinamento 2-opt..."

#: post_processors/transformers/optimize_transformer.py
msgid "Reassembling optimized workpieces..."
msgstr "Reunindo peças de trabalho otimizadas..."

#: post_processors/transformers/optimize_transformer.py
msgid "Workpiece optimization complete"
msgstr "Otimização da peça de trabalho concluída"

#: post_processors/transformers/optimize_transformer.py
msgid "Preprocessing for optimization..."
msgstr "Pré-processamento para otimização..."

#: post_processors/transformers/optimize_transformer.py
msgid "Analyzing and bucketing path segments..."
msgstr "Analisando e agrupando segmentos de caminho..."

#: post_processors/transformers/optimize_transformer.py
#, python-brace-format
msgid "Optimizing segment {i}/{total}..."
msgstr "Otimizando segmento {i}/{total}..."

#: post_processors/transformers/optimize_transformer.py
msgid "Finding nearest paths..."
msgstr "Encontrando caminhos mais próximos..."

#: post_processors/transformers/optimize_transformer.py
msgid "Reassembling optimized paths..."
msgstr "Reunindo caminhos otimizados..."

#: post_processors/transformers/optimize_transformer.py
msgid "Optimization complete"
msgstr "Otimização concluída"

#: post_processors/transformers/smooth_transformer.py
msgid "Smooth Path"
msgstr "Suavizar Caminho"

#: post_processors/transformers/smooth_transformer.py
msgid "Smooths the path by applying a Gaussian filter."
msgstr "Suaviza o caminho aplicando um filtro gaussiano."

#: post_processors/transformers/merge_lines_transformer.py
msgid "Merge Lines"
msgstr "Fundir linhas"

#: post_processors/transformers/merge_lines_transformer.py
msgid "Merges overlapping lines to avoid double passing."
msgstr "Funde linhas sobrepostas para evitar passagens duplas."

#: post_processors/transformers/overscan_transformer.py
msgid "Overscan"
msgstr "Sobrescan"

#: post_processors/transformers/overscan_transformer.py
msgid "Extends raster lines to ensure constant engraving speed."
msgstr "Estende linhas raster para garantir velocidade de gravação constante."

#: post_processors/transformers/crop_transformer.py
msgid "Crop to Stock"
msgstr "Recortar para Material"

#: post_processors/transformers/crop_transformer.py
msgid "Crops cutting lines to stock boundary."
msgstr "Recorta linhas de corte para o limite do material."

#: post_processors/transformers/multipass_transformer.py
msgid "Multi-Pass"
msgstr "Múltiplas Passagens"

#: post_processors/transformers/multipass_transformer.py
msgid "Repeats the path multiple times, optionally stepping down in Z."
msgstr "Repete o caminho múltiplas vezes, opcionalmente descendo em Z."

#: post_processors/transformers/tabs_transformer.py
msgid "Tabs"
msgstr "Abas de Fixação"

#: post_processors/transformers/tabs_transformer.py
msgid "Creates holding tabs by adding gaps or reducing power on cut paths"
msgstr ""
"Cria abas de fixação adicionando lacunas ou reduzindo a potência em caminhos "
"de corte"
