msgid "Air Assist"
msgstr "Повітряний обдув"

#: rayforge/core/capability.py
msgid "Kerf"
msgstr "Пропил"

#: rayforge/core/capability.py
msgid "The effective width of the laser beam"
msgstr "Ефективна ширина лазерного променя"

#: rayforge/core/capability.py
msgid "Engrave"
msgstr "Гравіювання"

#: rayforge/core/capability.py
msgid "Engrave Speed"
msgstr "Швидкість гравіювання"

#: rayforge/core/capability.py
msgid "Score"
msgstr "Надріз"

#: rayforge/core/capability.py
msgid "Score Speed"
msgstr "Швидкість надрізу"

#: rayforge/core/model_manager.py
#: rayforge/ui_gtk/settings/machine_settings_page.py
msgid "Machines"
msgstr "Верстати"

#: rayforge/core/model_manager.py
msgid "Complete machine models."
msgstr "Повні моделі машин."

#: rayforge/core/model_manager.py
msgid "Rotary"
msgstr "Поворотний"

#: rayforge/core/model_manager.py
msgid "Rotary and workholding models."
msgstr "Поворотні моделі та моделі кріплення."

#: rayforge/core/model_manager.py
#: rayforge/ui_gtk/machine/laser_preferences_page.py
msgid "Laser Heads"
