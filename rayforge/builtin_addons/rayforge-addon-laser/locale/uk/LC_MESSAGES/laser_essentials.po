#: laser_essentials/producers/raster_producer.py
msgid "Variable Power"
msgstr "Змінна потужність"

#: laser_essentials/producers/raster_producer.py
msgid "Constant Power"
msgstr "Постійна потужність"

#: laser_essentials/producers/raster_producer.py
msgid "Dither"
msgstr "Дитеринг"

#: laser_essentials/producers/raster_producer.py
msgid "Multiple Depths"
msgstr "Кілька глибин"

#: laser_essentials/producers/raster_producer.py
msgid "Variable"
msgstr "Змінна"

#: laser_essentials/producers/raster_producer.py
msgid "Constant"
msgstr "Стала"

#: laser_essentials/producers/raster_producer.py
msgid "Multi-Pass"
msgstr "Багатопрохідний"

#: laser_essentials/producers/shrinkwrap_producer.py
#: laser_essentials/producers/contour_producer.py
msgid "Optimizing path with curves..."
msgstr "Оптимізація шляху за допомогою кривих..."

#: laser_essentials/producers/contour_producer.py
msgid "Inside-Outside"
msgstr "Зсередини-назовні"

#: laser_essentials/producers/contour_producer.py
msgid "Outside-Inside"
msgstr "Ззовні-всередину"

#: laser_essentials/widgets/raster_widget.py
msgid "Configure how the laser engraves your image."
msgstr "Налаштуйте, як лазер гравіює ваше зображення."

#: laser_essentials/widgets/raster_widget.py
msgid "Mode"
msgstr "Режим"

#: laser_essentials/widgets/raster_widget.py
msgid "Threshold"
msgstr "Поріг"

#: laser_essentials/widgets/raster_widget.py
msgid "Brightness cutoff for black/white (0-255)"
msgstr "Поріг яскравості для чорно-білого (0-255)"

#: laser_essentials/widgets/raster_widget.py
msgid "Engraving Method"
msgstr "Метод гравіювання"

#: laser_essentials/widgets/raster_widget.py
msgid "Algorithm for converting grayscale to binary"
msgstr "Алгоритм перетворення відтінків сірого у двійковий формат"

#: laser_essentials/widgets/raster_widget.py
msgid "Auto Levels"
msgstr "Авто рівні"

#: laser_essentials/widgets/raster_widget.py
msgid "Automatically adjust black/white points"
msgstr "Автоматично налаштувати чорні/білі точки"

#: laser_essentials/widgets/raster_widget.py
msgid "Brightness Range"
msgstr "Діапазон яскравості"

#: laser_essentials/widgets/raster_widget.py
msgid "Auto-adjusted based on image content"
msgstr "Автоналаштування на основі вмісту зображення"

#: laser_essentials/widgets/raster_widget.py
msgid "Drag markers to set black/white points"
msgstr "Перетягніть маркери, щоб встановити чорні/білі точки"

#: laser_essentials/widgets/raster_widget.py
msgid "Min Power"
msgstr "Мін. потужність"

#: laser_essentials/widgets/raster_widget.py
#, python-format
msgid "Power for lightest areas, as a % of the step's main power"
msgstr "Потужність для найсвітліших ділянок, у % від основної потужності кроку"

#: laser_essentials/widgets/raster_widget.py
msgid "Max Power"
msgstr "Макс. потужність"

#: laser_essentials/widgets/raster_widget.py
#, python-format
msgid "Power for darkest areas, as a % of the step's main power"
msgstr "Потужність для найтемніших ділянок, у % від основної потужності кроку"

#: laser_essentials/widgets/raster_widget.py
msgid "Power Levels"
msgstr "Рівні потужності"

#: laser_essentials/widgets/raster_widget.py
msgid "Number of discrete power steps (lower = fewer moves)"
msgstr "Кількість дискретних кроків потужності (менше = менше рухів)"

#: laser_essentials/widgets/raster_widget.py
msgid "Number of Depth Levels"
msgstr "Кількість рівнів глибини"

#: laser_essentials/widgets/raster_widget.py
msgid "Z Step-Down per Level (mm)"
msgstr "Зниження Z на рівень (мм)"

#: laser_essentials/widgets/raster_widget.py
msgid "Rotate Angle Per Pass"
msgstr "Кут повороту за прохід"

#: laser_essentials/widgets/raster_widget.py
msgid "Degrees to rotate each successive pass"
msgstr "Градуси повороту кожного наступного проходу"

#: laser_essentials/widgets/raster_widget.py
msgid "Engraving Pattern"
msgstr "Візерунок гравіювання"

#: laser_essentials/widgets/raster_widget.py
msgid "Settings that control the scan line pattern and orientation."
msgstr "Налаштування, що керують візерунком та орієнтацією ліній сканування."

#: laser_essentials/widgets/raster_widget.py
msgid "Angle"
msgstr "Кут"

#: laser_essentials/widgets/raster_widget.py
msgid "Angle of scan lines in degrees"
msgstr "Кут ліній сканування в градусах"

#: laser_essentials/widgets/raster_widget.py
msgid "Cross-Hatch"
msgstr "Перехресна штриховка"

#: laser_essentials/widgets/raster_widget.py
msgid "Add a second pass at 90 degrees"
msgstr "Додати другий прохід під 90 градусів"

#: laser_essentials/widgets/raster_widget.py
msgid "Line Spacing"
msgstr "Інтервал між лініями"

#: laser_essentials/widgets/raster_widget.py
msgid "Distance between scan lines"
msgstr "Відстань між лініями сканування"

#: laser_essentials/widgets/raster_widget.py
msgid "Sample Interval"
msgstr "Інтервал вибірки"

#: laser_essentials/widgets/raster_widget.py
msgid ""
"Distance between power samples along scan line. Lower values improve "
"accuracy, but increase output size."
msgstr ""
"Відстань між вибірками потужності вздовж лінії сканування. Менші значення "
"покращують точність, але збільшують розмір виводу."

#: laser_essentials/widgets/raster_widget.py
msgid "Invert"
msgstr "Інвертувати"

#: laser_essentials/widgets/raster_widget.py
msgid "Engrave white areas instead of black areas"
msgstr "Гравіювати білі ділянки замість чорних"

#: laser_essentials/widgets/raster_widget.py
#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Change Power Range"
msgstr "Змінити діапазон потужності"

#: laser_essentials/widgets/raster_widget.py
msgid "Change Min Power"
msgstr "Змінити мін. потужність"

#: laser_essentials/widgets/raster_widget.py
msgid "Change Max Power"
msgstr "Змінити макс. потужність"

#: laser_essentials/widgets/raster_widget.py
msgid "Min Power (Black)"
msgstr "Мін. потужність (чорне)"

#: laser_essentials/widgets/raster_widget.py
msgid "Max Power (White)"
msgstr "Макс. потужність (біле)"

#: laser_essentials/widgets/raster_widget.py
msgid "Min Power (White)"
msgstr "Мін. потужність (біле)"

#: laser_essentials/widgets/raster_widget.py
msgid "Max Power (Black)"
msgstr "Макс. потужність (чорне)"

#: laser_essentials/widgets/raster_widget.py
msgid "Change engraving setting"
msgstr "Змінити налаштування гравіювання"

#: laser_essentials/widgets/shrinkwrap_widget.py
msgid "Gravity"
msgstr "Гравітація"

#: laser_essentials/widgets/shrinkwrap_widget.py
msgid "Pulls the hull inward. 0.0 is a standard convex hull"
msgstr "Тягне оболонку всередину. 0.0 — стандартна опукла оболонка"

#: laser_essentials/widgets/shrinkwrap_widget.py
#: laser_essentials/widgets/frame_widget.py
#: laser_essentials/widgets/contour_widget.py
msgid "Cut Side"
msgstr "Сторона різу"

#: laser_essentials/widgets/shrinkwrap_widget.py
#: laser_essentials/widgets/frame_widget.py
#: laser_essentials/widgets/contour_widget.py
msgid "Path Offset"
msgstr "Зміщення контуру"

#: laser_essentials/widgets/shrinkwrap_widget.py
#: laser_essentials/widgets/contour_widget.py
msgid ""
"Absolute distance from original path in machine units, direction is "
"controlled by Cut Side"
msgstr ""
"Абсолютна відстань від оригінального контуру в одиницях машини, напрямок "
"контролюється стороною різу"

#: laser_essentials/widgets/shrinkwrap_widget.py
msgid "Change Shrinkwrap Setting"
msgstr "Змінити налаштування стягування"

#: laser_essentials/widgets/frame_widget.py
msgid "Absolute distance from content boundary in machine units"
msgstr "Абсолютна відстань від межі вмісту в одиницях машини"

#: laser_essentials/widgets/frame_widget.py
msgid "Change Frame Setting"
msgstr "Змінити налаштування рамки"

#: laser_essentials/widgets/contour_widget.py
msgid "Remove Inner Paths"
msgstr "Видалити внутрішні контури"

#: laser_essentials/widgets/contour_widget.py
msgid "If enabled, only trace the outer outline of shapes"
msgstr "Якщо увімкнено, трасувати лише зовнішній контур фігур"

#: laser_essentials/widgets/contour_widget.py
msgid "Cut Order"
msgstr "Порядок різання"

#: laser_essentials/widgets/contour_widget.py
msgid "Processing order for nested paths"
msgstr "Порядок обробки вкладених контурів"

#: laser_essentials/widgets/contour_widget.py
msgid "Rescan Content"
msgstr "Пересканувати вміст"

#: laser_essentials/widgets/contour_widget.py
msgid "Ignore source geometry and re-trace within the workpiece"
msgstr "Ігнорувати вихідну геометрію і повторно трасувати в робочій деталі"

#: laser_essentials/widgets/contour_widget.py
msgid "Tracing Threshold"
msgstr "Поріг трасування"

#: laser_essentials/widgets/contour_widget.py
msgid "Brightness level (0.0-1.0) to define edges"
msgstr "Рівень яскравості (0.0-1.0) для визначення країв"

#: laser_essentials/widgets/contour_widget.py
msgid "Change Edge Tracer Setting"
msgstr "Змінити налаштування трасування країв"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Presets"
msgstr "Пресети"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Load common test configurations"
msgstr "Завантажити типові конфігурації тестування"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Test Type"
msgstr "Тип тесту"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Cut: outlines; Engrave: fills with raster lines"
msgstr "Різання: контури; Гравіювання: заповнення растровими лініями"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Grid Mode"
msgstr "Режим сітки"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Choose which parameters to vary on axes"
msgstr "Виберіть, які параметри змінювати на осях"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Parameters"
msgstr "Параметри"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Define the parameter ranges for the test grid"
msgstr "Визначте діапазони параметрів для тестової сітки"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Fixed Speed"
msgstr "Фіксована швидкість"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Constant speed for all cells (mm/min)"
msgstr "Постійна швидкість для всіх клітинок (мм/хв)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Fixed Power (%)"
msgstr "Фіксована потужність (%)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Constant power for all cells"
msgstr "Постійна потужність для всіх клітинок"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Minimum Power (%)"
msgstr "Мінімальна потужність (%)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "For first column"
msgstr "Для першого стовпця"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Maximum Power (%)"
msgstr "Максимальна потужність (%)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "For last column"
msgstr "Для останнього стовпця"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Minimum Speed"
msgstr "Мінімальна швидкість"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Starting speed (mm/min)"
msgstr "Початкова швидкість (мм/хв)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Maximum Speed"
msgstr "Максимальна швидкість"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Ending speed (mm/min)"
msgstr "Кінцева швидкість (мм/хв)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Minimum Passes"
msgstr "Мінімум проходів"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Starting number of passes"
msgstr "Початкова кількість проходів"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Maximum Passes"
msgstr "Максимум проходів"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Ending number of passes"
msgstr "Кінцева кількість проходів"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Label Engrave Power (%)"
msgstr "Потужність гравіювання міток (%)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Label Engrave Speed"
msgstr "Швидкість гравіювання міток"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Speed for engraving labels (mm/min)"
msgstr "Швидкість гравіювання міток (мм/хв)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Columns (Power Steps)"
msgstr "Стовпці (кроки потужності)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Number of power variations"
msgstr "Кількість варіацій потужності"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Rows (Speed Steps)"
msgstr "Рядки (кроки швидкості)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Number of speed variations"
msgstr "Кількість варіацій швидкості"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Shape Size"
msgstr "Розмір фігури"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Size of each test square (mm)"
msgstr "Розмір кожного тестового квадрата (мм)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Spacing"
msgstr "Інтервал"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Gap between test squares (mm)"
msgstr "Проміжок між тестовими квадратами (мм)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Line Interval"
msgstr "Інтервал ліній"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid ""
"Distance between scan lines in machine units (for Engrave mode). Leave at 0 "
"to use laser spot size."
msgstr ""
"Відстань між лініями сканування в одиницях верстата (для режиму "
"гравіювання). Залиште 0, щоб використовувати розмір плями лазера."

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Include Labels"
msgstr "Включити мітки"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Add speed/power annotations to the grid"
msgstr "Додати анотації швидкості/потужності до сітки"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Rows (Passes Steps)"
msgstr "Рядки (Кроки проходів)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Number of passes variations"
msgstr "Кількість варіацій проходів"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Columns (Speed Steps)"
msgstr "Стовпці (Кроки швидкості)"

#: laser_essentials/widgets/material_test_grid_widget.py
#, python-brace-format
msgid "Change {param_name}"
msgstr "Змінити {param_name}"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Change Grid Dimensions"
msgstr "Змінити розміри сітки"

#: laser_essentials/worker.py
msgid "Create Material Test Grid"
msgstr "Створити сітку тестування матеріалу"

#: laser_essentials/steps/shrinkwrap_step.py
msgid "Shrink Wrap"
msgstr "Обтискання"

#: laser_essentials/steps/frame_step.py
msgid "Frame"
msgstr "Рамка"

#: laser_essentials/steps/raster_step.py
msgid "Engrave"
msgstr "Гравіювання"

#: laser_essentials/steps/contour_step.py
msgid "Contour"
msgstr "Контур"

#: laser_essentials/steps/material_test.py
#: laser_essentials/commands/material_test_cmd.py
msgid "Material Test Grid"
msgstr "Сітка тестування матеріалу"

#: laser_essentials/commands/material_test_cmd.py
msgid "Add Material Test"
msgstr "Додати тест матеріалу"
