#: laser_essentials/widgets/raster_widget.py
msgid "Configure how the laser engraves your image."
msgstr "Configurer la gravure de votre image par le laser."

#: laser_essentials/widgets/raster_widget.py
msgid "Mode"
msgstr "Mode"

#: laser_essentials/widgets/raster_widget.py
msgid "Threshold"
msgstr "Seuil"

#: laser_essentials/widgets/raster_widget.py
msgid "Brightness cutoff for black/white (0-255)"
msgstr "Seuil de luminosité pour le noir/blanc (0-255)"

#: laser_essentials/widgets/raster_widget.py
msgid "Engraving Method"
msgstr "Méthode de gravure"

