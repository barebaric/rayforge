#: laser_essentials/producers/raster_producer.py
msgid "Variable Power"
msgstr "Variable Leistung"

#: laser_essentials/producers/raster_producer.py
msgid "Constant Power"
msgstr "Konstante Leistung"

#: laser_essentials/producers/raster_producer.py
msgid "Dither"
msgstr "Dithering"

#: laser_essentials/producers/raster_producer.py
msgid "Multiple Depths"
msgstr "Mehrere Tiefen"

#: laser_essentials/producers/shrinkwrap_producer.py
#: laser_essentials/producers/contour_producer.py
msgid "Optimizing path with arcs..."
msgstr "Pfad wird mit Bögen optimiert..."

#: laser_essentials/producers/contour_producer.py
msgid "Inside-Outside"
msgstr "Innen-Außen"

#: laser_essentials/producers/contour_producer.py
msgid "Outside-Inside"
msgstr "Außen-Innen"

#: laser_essentials/widgets/raster_widget.py
msgid "Configure how the laser engraves your image."
msgstr "Konfiguriere, wie der Laser dein Bild graviert."

#: laser_essentials/widgets/raster_widget.py
msgid "Mode"
msgstr "Modus"

#: laser_essentials/widgets/raster_widget.py
msgid "Threshold"
msgstr "Schwellenwert"

#: laser_essentials/widgets/raster_widget.py
msgid "Brightness cutoff for black/white (0-255)"
msgstr "Helligkeitsgrenzwert für Schwarz/Weiß (0-255)"

#: laser_essentials/widgets/raster_widget.py
msgid "Engraving Method"
msgstr "Gravurmethode"

#: laser_essentials/widgets/raster_widget.py
msgid "Algorithm for converting grayscale to binary"
msgstr "Algorithmus zum Konvertieren von Graustufen in Binär"

#: laser_essentials/widgets/raster_widget.py
msgid "Auto Levels"
msgstr "Automatische Pegel"

#: laser_essentials/widgets/raster_widget.py
msgid "Automatically adjust black/white points"
msgstr "Schwarz/Weiß-Punkte automatisch anpassen"

#: laser_essentials/widgets/raster_widget.py
msgid "Brightness Range"
msgstr "Helligkeitsbereich"

#: laser_essentials/widgets/raster_widget.py
msgid "Auto-adjusted based on image content"
msgstr "Automatisch angepasst basierend auf Bildinhalt"

#: laser_essentials/widgets/raster_widget.py
msgid "Drag markers to set black/white points"
msgstr "Ziehe die Markierungen, um Schwarz-/Weißpunkte festzulegen"

#: laser_essentials/widgets/raster_widget.py
msgid "Min Power"
msgstr "Min. Leistung"

#: laser_essentials/widgets/raster_widget.py
#, python-format
msgid "Power for lightest areas, as a % of the step's main power"
msgstr ""
"Leistung für die hellsten Bereiche, als %% der Hauptleistung des Schritts"

#: laser_essentials/widgets/raster_widget.py
msgid "Max Power"
msgstr "Max. Leistung"

#: laser_essentials/widgets/raster_widget.py
#, python-format
msgid "Power for darkest areas, as a % of the step's main power"
msgstr ""
"Leistung für die dunkelsten Bereiche, als %% der Hauptleistung des Schritts"

#: laser_essentials/widgets/raster_widget.py
msgid "Power Levels"
msgstr "Leistungsstufen"

#: laser_essentials/widgets/raster_widget.py
msgid "Number of discrete power steps (lower = fewer moves)"
msgstr "Anzahl der diskreten Leistungsstufen (weniger = weniger Bewegungen)"

#: laser_essentials/widgets/raster_widget.py
msgid "Number of Depth Levels"
msgstr "Anzahl der Tiefenstufen"

#: laser_essentials/widgets/raster_widget.py
msgid "Z Step-Down per Level (mm)"
msgstr "Z-Absenkung pro Stufe (mm)"

#: laser_essentials/widgets/raster_widget.py
msgid "Rotate Angle Per Pass"
msgstr "Rotationswinkel pro Durchgang"

#: laser_essentials/widgets/raster_widget.py
msgid "Degrees to rotate each successive pass"
msgstr "Grad, um die jeder folgende Durchgang rotiert wird"

#: laser_essentials/widgets/raster_widget.py
msgid "Engraving Pattern"
msgstr "Gravurmuster"

#: laser_essentials/widgets/raster_widget.py
msgid "Settings that control the scan line pattern and orientation."
msgstr "Einstellungen, die das Scanlinienmuster und die Ausrichtung steuern."

#: laser_essentials/widgets/raster_widget.py
msgid "Angle"
msgstr "Winkel"

#: laser_essentials/widgets/raster_widget.py
msgid "Angle of scan lines in degrees"
msgstr "Winkel der Scanlinien in Grad"

#: laser_essentials/widgets/raster_widget.py
msgid "Cross-Hatch"
msgstr "Kreuzschraffur"

#: laser_essentials/widgets/raster_widget.py
msgid "Add a second pass at 90 degrees"
msgstr "Einen zweiten Durchgang bei 90 Grad hinzufügen"

#: laser_essentials/widgets/raster_widget.py
msgid "Line Spacing"
msgstr "Linienabstand"

#: laser_essentials/widgets/raster_widget.py
msgid "Distance between scan lines"
msgstr "Abstand zwischen Scanzeilen"

#: laser_essentials/widgets/raster_widget.py
msgid "Sample Interval"
msgstr "Abtastintervall"

#: laser_essentials/widgets/raster_widget.py
msgid ""
"Distance between power samples along scan line. Lower values improve "
"accuracy, but increase output size."
msgstr ""
"Abstand zwischen Leistungsabtastungen entlang der Scanzeile. Niedrigere "
"Werte verbessern die Genauigkeit, erhöhen aber die Ausgabegröße."

#: laser_essentials/widgets/raster_widget.py
msgid "Invert"
msgstr "Invertieren"

#: laser_essentials/widgets/raster_widget.py
msgid "Engrave white areas instead of black areas"
msgstr "Weiße Bereiche anstelle von schwarzen Bereichen gravieren"

#: laser_essentials/widgets/raster_widget.py
#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Change Power Range"
msgstr "Leistungsbereich ändern"

#: laser_essentials/widgets/raster_widget.py
msgid "Change Min Power"
msgstr "Min. Leistung ändern"

#: laser_essentials/widgets/raster_widget.py
msgid "Change Max Power"
msgstr "Max. Leistung ändern"

#: laser_essentials/widgets/raster_widget.py
msgid "Min Power (Black)"
msgstr "Min. Leistung (Schwarz)"

#: laser_essentials/widgets/raster_widget.py
msgid "Max Power (White)"
msgstr "Max. Leistung (Weiß)"

#: laser_essentials/widgets/raster_widget.py
msgid "Min Power (White)"
msgstr "Minimale Leistung (Weiß)"

#: laser_essentials/widgets/raster_widget.py
msgid "Max Power (Black)"
msgstr "Maximale Leistung (Schwarz)"

#: laser_essentials/widgets/raster_widget.py
msgid "Change engraving setting"
msgstr "Gravureinstellung ändern"

#: laser_essentials/widgets/shrinkwrap_widget.py
msgid "Gravity"
msgstr "Anziehung"

#: laser_essentials/widgets/shrinkwrap_widget.py
msgid "Pulls the hull inward. 0.0 is a standard convex hull"
msgstr "Zieht die Hülle nach innen. 0.0 ist eine standardmäßige konvexe Hülle"

#: laser_essentials/widgets/shrinkwrap_widget.py
#: laser_essentials/widgets/frame_widget.py
#: laser_essentials/widgets/contour_widget.py
msgid "Cut Side"
msgstr "Schnittseite"

#: laser_essentials/widgets/shrinkwrap_widget.py
#: laser_essentials/widgets/frame_widget.py
#: laser_essentials/widgets/contour_widget.py
msgid "Path Offset"
msgstr "Pfadversatz"

#: laser_essentials/widgets/shrinkwrap_widget.py
#: laser_essentials/widgets/contour_widget.py
msgid ""
"Absolute distance from original path in machine units, direction is "
"controlled by Cut Side"
msgstr ""
"Absoluter Abstand vom Originalpfad in Maschineneinheiten, die Richtung wird "
"durch die Schnittseite bestimmt"

#: laser_essentials/widgets/shrinkwrap_widget.py
msgid "Change Shrinkwrap Setting"
msgstr "Umhüllungseinstellung ändern"

#: laser_essentials/widgets/frame_widget.py
msgid "Absolute distance from content boundary in machine units"
msgstr "Absoluter Abstand von der Inhaltsbegrenzung in Maschineneinheiten"

#: laser_essentials/widgets/frame_widget.py
msgid "Change Frame Setting"
msgstr "Rahmeneinstellung ändern"

#: laser_essentials/widgets/contour_widget.py
msgid "Remove Inner Paths"
msgstr "Innere Pfade entfernen"

#: laser_essentials/widgets/contour_widget.py
msgid "If enabled, only trace the outer outline of shapes"
msgstr "Wenn aktiviert, wird nur die äußere Kontur von Formen nachgezeichnet."

#: laser_essentials/widgets/contour_widget.py
msgid "Cut Order"
msgstr "Schnittreihenfolge"

#: laser_essentials/widgets/contour_widget.py
msgid "Processing order for nested paths"
msgstr "Verarbeitungsreihenfolge für verschachtelte Pfade"

#: laser_essentials/widgets/contour_widget.py
msgid "Rescan Content"
msgstr "Inhalt neu scannen"

#: laser_essentials/widgets/contour_widget.py
msgid "Ignore source geometry and re-trace within the workpiece"
msgstr ""
"Quellgeometrie ignorieren und innerhalb des Werkstücks neu nachzeichnen"

#: laser_essentials/widgets/contour_widget.py
msgid "Tracing Threshold"
msgstr "Nachzeichnungsschwellenwert"

#: laser_essentials/widgets/contour_widget.py
msgid "Brightness level (0.0-1.0) to define edges"
msgstr "Helligkeitsstufe (0.0-1.0) zur Definition von Kanten"

#: laser_essentials/widgets/contour_widget.py
msgid "Change Edge Tracer Setting"
msgstr "Einstellung für Konturverfolgung ändern"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Presets"
msgstr "Voreinstellungen"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Load common test configurations"
msgstr "Häufige Testkonfigurationen laden"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Test Type"
msgstr "Testtyp"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Cut: outlines; Engrave: fills with raster lines"
msgstr "Schnitt: Umrisse; Gravieren: Füllt mit Rasterlinien"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Speed &amp; Power"
msgstr "Geschwindigkeit &amp; Leistung"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Define the range of speeds and powers for the test grid"
msgstr ""
"Definiere den Bereich der Geschwindigkeiten und Leistungen für das Testgitter"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Minimum Power (%)"
msgstr "Minimale Leistung (%)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "For first column"
msgstr "Für die erste Spalte"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Maximum Power (%)"
msgstr "Maximale Leistung (%)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "For last column"
msgstr "Für die letzte Spalte"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Minimum Speed"
msgstr "Minimale Geschwindigkeit"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Starting speed (mm/min)"
msgstr "Startgeschwindigkeit (mm/min)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Maximum Speed"
msgstr "Maximale Geschwindigkeit"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Ending speed (mm/min)"
msgstr "Endgeschwindigkeit (mm/min)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Columns (Power Steps)"
msgstr "Spalten (Leistungsschritte)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Number of power variations"
msgstr "Anzahl der Leistungsvariationen"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Rows (Speed Steps)"
msgstr "Zeilen (Geschwindigkeitsschritte)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Number of speed variations"
msgstr "Anzahl der Geschwindigkeitvariationen"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Shape Size"
msgstr "Formgröße"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Size of each test square (mm)"
msgstr "Größe jedes Testquadrats (mm)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Spacing"
msgstr "Abstand"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Gap between test squares (mm)"
msgstr "Abstand zwischen Testquadraten (mm)"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Line Interval"
msgstr "Linienabstand"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid ""
"Distance between scan lines in machine units (for Engrave mode). Leave at 0 "
"to use laser spot size."
msgstr ""
"Abstand zwischen Scanlinien in Maschineneinheiten (für Gravurmodus). Auf 0 "
"setzen, um die Laserpunktgröße zu verwenden."

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Include Labels"
msgstr "Beschriftungen einschließen"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Add speed/power annotations to the grid"
msgstr "Geschwindigkeits-/Leistungs-Anmerkungen zum Gitter hinzufügen"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Label Engrave Power (%)"
msgstr "Beschriftungs-Gravurleistung (%)"

#: laser_essentials/widgets/material_test_grid_widget.py
#, python-brace-format
msgid "Change {param_name}"
msgstr "Ändere {param_name}"

#: laser_essentials/widgets/material_test_grid_widget.py
msgid "Change Grid Dimensions"
msgstr "Gitterabmessungen ändern"

